<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <RelativeLayout
        android:id="@+id/headerEnrollForm"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="36dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="0dp">

        <ImageView
            android:id="@+id/ivBackEnrollForm"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:contentDescription="Back"
            android:src="@drawable/ic_back_arrow"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/enrollment"
            android:textColor="@color/blue_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/btnEnrollNowFinal"
        app:layout_constraintTop_toBottomOf="@id/headerEnrollForm">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill your details to enroll,"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="#2C3E50"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"
                tools:ignore="HardcodedText" />
            <EditText
                android:id="@+id/etEnrollName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/gray_field"
                android:hint="Enter your full name"
                android:importantForAutofill="no"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textColor="#2C3E50"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"
                tools:ignore="HardcodedText" />
            <EditText
                android:id="@+id/etEnrollEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/gray_field"
                android:hint="Enter your email"
                android:importantForAutofill="no"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="16dp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number"
                android:textColor="#2C3E50"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"
                tools:ignore="HardcodedText" />
            <EditText
                android:id="@+id/etEnrollPhone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/gray_field"
                android:hint="Enter your phone number"
                android:importantForAutofill="no"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:inputType="phone"
                android:layout_marginBottom="16dp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Month"
                android:textColor="#2C3E50"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"
                tools:ignore="HardcodedText" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/gray_field"
                android:layout_marginBottom="24dp">

                <Spinner
                    android:id="@+id/spinnerMonths"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="12dp"
                    android:spinnerMode="dropdown"/>
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnEnrollNowFinal"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="24dp"
        android:backgroundTint="#F39C12"
        android:text="Enroll Now"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:ignore="HardcodedText" />

</androidx.constraintlayout.widget.ConstraintLayout>