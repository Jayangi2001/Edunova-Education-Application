<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDynamicQuestionNum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/question_x"
            android:textColor="@color/blue_primary"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etDynamicQuestionText"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:autofillHints=""
            android:background="@drawable/gray_field"
            android:hint="@string/type_question_text"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:padding="10dp"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etDynamicOptA"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:autofillHints=""
                android:background="@drawable/gray_field"
                android:hint="@string/option_a"
                android:paddingHorizontal="12dp"
                android:textSize="13sp"
                tools:ignore="TextFields" />
            <EditText
                android:id="@+id/etDynamicOptB"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/gray_field"
                android:hint="@string/option_b"
                android:importantForAutofill="no"
                android:paddingHorizontal="12dp"
                android:textSize="13sp"
                tools:ignore="TextFields" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etDynamicOptC"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/gray_field"
                android:hint="@string/option_c"
                android:importantForAutofill="no"
                android:paddingHorizontal="12dp"
                android:textSize="13sp"
                tools:ignore="Autofill,TextFields" />
            <EditText
                android:id="@+id/etDynamicOptD"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/gray_field"
                android:hint="@string/option_d"
                android:importantForAutofill="no"
                android:paddingHorizontal="12dp"
                android:textSize="13sp"
                tools:ignore="TextFields" />
        </LinearLayout>

        <EditText
            android:id="@+id/etDynamicCorrect"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/gray_field"
            android:hint="@string/correct_answer_a_b_c_or_d"
            android:importantForAutofill="no"
            android:inputType="textCapCharacters"
            android:maxLength="1"
            android:paddingHorizontal="12dp"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>