<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <RelativeLayout
        android:id="@+id/headerClassroom"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="36dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="0dp">

        <ImageView
            android:id="@+id/ivBackClassroom"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:contentDescription="Back"
            android:src="@drawable/ic_back_arrow"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Physics - Grade 12"
            android:textColor="@color/blue_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerClassroom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gray_field"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEXT LIVE CLASS"
                    android:textColor="#E74C3C"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mechanics - Lesson 05"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tonight at 6:00 PM"
                    android:textColor="#7F8C8D"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"
                    tools:ignore="HardcodedText" />

                <Button
                    android:id="@+id/btnJoinLive"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#E74C3C"
                    android:text="🔴 Join Live Class Now"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Course Materials"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                tools:ignore="HardcodedText" />

            <RelativeLayout
                android:id="@+id/btnDownloadTute"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:background="@drawable/gray_field"
                android:padding="16dp"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:id="@+id/ivPdfIcon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/img_16"
                    android:layout_centerVertical="true"
                    tools:ignore="ContentDescription" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/ivPdfIcon"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true"
                    tools:ignore="RelativeOverlap">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mechanics Tute - 05.pdf" android:textStyle="bold" android:textColor="#2C3E50" android:textSize="13sp"
                        tools:ignore="HardcodedText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/_4_2_mb_pdf_document" android:textSize="11sp" android:textColor="#7F8C8D"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_arrow"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    tools:ignore="ContentDescription" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/btnWatchRecording"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:background="@drawable/gray_field"
                android:padding="16dp"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:id="@+id/ivVideoIcon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_vid"
                    android:layout_centerVertical="true"
                    tools:ignore="ContentDescription" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/ivVideoIcon"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Last Week Class Recording" android:textStyle="bold" android:textColor="#2C3E50" android:textSize="13sp"
                        tools:ignore="HardcodedText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mechanics - Lesson 04 (Video)" android:textSize="11sp" android:textColor="#7F8C8D"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_arrow"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    tools:ignore="ContentDescription" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/btnTakeQuiz"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:background="@drawable/gray_field"
                android:padding="16dp"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:id="@+id/ivQuizIcon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/img_17"
                    android:layout_centerVertical="true"
                    tools:ignore="ContentDescription" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/ivQuizIcon"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weekly MCQ Paper - 04" android:textStyle="bold" android:textColor="#2C3E50" android:textSize="13sp"
                        tools:ignore="HardcodedText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20 Questions | 40 Minutes" android:textSize="11sp" android:textColor="#7F8C8D"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_arrow"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    tools:ignore="ContentDescription" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>