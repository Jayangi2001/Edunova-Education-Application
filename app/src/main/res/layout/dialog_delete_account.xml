<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_background"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#D0D5DD"
        android:backgroundTint="#D0D5DD"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delete Account"
        android:textColor="#E74C3C"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"
        tools:ignore="HardcodedText" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Are you sure you want to delete your account? This action cannot be undone."
        android:textColor="#4A5568"
        android:textSize="14sp"
        android:textAlignment="center"
        android:layout_marginBottom="24dp"
        tools:ignore="HardcodedText" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnCancelDelete"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#EDF2F7"
            android:text="Cancel"
            android:textColor="#4A5568"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btnConfirmDelete"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="#E74C3C"
            android:text="Delete"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            tools:ignore="HardcodedText" />

    </LinearLayout>

</LinearLayout>