<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <ImageView
            android:id="@+id/ivHeaderBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back_arrow"
            android:contentDescription="Back Button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="HardcodedText" />

        <ImageView
            android:id="@+id/ivNotification"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/img_6"
            android:contentDescription="@string/notifications"
            app:layout_constraintBottom_toBottomOf="@id/ivHeaderBack"
            app:layout_constraintEnd_toStartOf="@id/ivProfile"
            app:layout_constraintTop_toTopOf="@id/ivHeaderBack" />

        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/img_4"
            android:contentDescription="Profile Picture"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="@id/ivHeaderBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivHeaderBack"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvWelcomeUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Welcome Back, Tharushi 👋"
            android:textColor="@color/blue_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivHeaderBack"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:id="@+id/llFixedTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvWelcomeUser"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/tabSaved"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#E2E8F0"
                android:padding="0dp"
                android:text="Saved"
                android:textColor="#334155"
                android:textSize="11sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                tools:ignore="ButtonStyle,HardcodedText" />

            <Button
                android:id="@+id/tabDashboard"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="#1E3A8A"
                android:padding="0dp"
                android:text="Dashboard"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                tools:ignore="ButtonStyle" />

            <Button
                android:id="@+id/tabMyCourses"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="#E2E8F0"
                android:padding="0dp"
                android:text="Courses"
                android:textColor="#334155"
                android:textSize="11sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                tools:ignore="ButtonStyle,HardcodedText" />

            <Button
                android:id="@+id/tabQuiz"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:backgroundTint="#E2E8F0"
                android:padding="0dp"
                android:text="Quiz"
                android:textColor="#334155"
                android:textSize="11sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                tools:ignore="ButtonStyle,HardcodedText" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOngoingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Are You Interested... Join now"
            android:textColor="@color/text_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llFixedTabs"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvOngoingSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="🔴 Ongoing"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvOngoingLabel"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:id="@+id/llCardsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvOngoingSub"
            tools:layout_editor_absoluteX="32dp">

            <LinearLayout
                android:id="@+id/cardBiology"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@android:color/white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:contentDescription="Biology Course"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_3"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Biology"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conducted by\nMrs. Shriyani"
                    android:textColor="@color/text_light"
                    android:textSize="11sp"
                    tools:ignore="HardcodedText" />

                <Button
                    android:id="@+id/btnJoinBiology"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/orange_accent"
                    android:padding="0dp"
                    android:text="Join Now"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardPhysics"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@android:color/white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:contentDescription="Physics Course"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_5"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Physics"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conducted by\nMr. Sarath"
                    android:textColor="@color/text_light"
                    android:textSize="11sp"
                    tools:ignore="HardcodedText" />

                <Button
                    android:id="@+id/btnJoinPhysics"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/orange_accent"
                    android:padding="0dp"
                    android:text="Join Now"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvUpcomingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="40dp"
            android:text="Upcoming..."
            android:textColor="@color/text_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llCardsContainer"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:id="@+id/llSchedule1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@android:color/white"
            android:orientation="horizontal"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvUpcomingLabel"
            tools:layout_editor_absoluteX="24dp">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:contentDescription="Schedule Icon"
                android:src="@drawable/img_17"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Physics - Quiz From Light &amp; optics"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="23rd Monday\n4:30 p.m"
                android:textAlignment="viewEnd"
                android:textColor="@color/text_light"
                android:textSize="11sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llSchedule2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@android:color/white"
            android:orientation="horizontal"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/llSchedule1"
            tools:layout_editor_absoluteX="24dp">

            <ImageView
                android:layout_width="29dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:contentDescription="Schedule Icon"
                android:src="@drawable/img_17"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Organic Chemistry - Part 2"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25th Wednesday\n7:00 p.m"
                android:textAlignment="viewEnd"
                android:textColor="@color/text_light"
                android:textSize="11sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>