<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivEditBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_back_arrow"
        android:contentDescription="Go Back"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvEditTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.02"
        android:text="Edit Profile"
        android:textColor="@color/blue_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ivEditBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivEditBack"
        app:layout_constraintVertical_bias="1.0"
        tools:ignore="HardcodedText" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/btnSaveProfile"
        app:layout_constraintTop_toBottomOf="@id/tvEditTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginVertical="20dp">

                <FrameLayout
                    android:id="@+id/editImageContainer"
                    android:layout_width="95dp"
                    android:layout_height="95dp"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivEditProfilePic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_4"
                        android:strokeColor="#FFFFFF"
                        android:translationZ="2dp"
                        app:shapeAppearanceOverlay="@style/CircleImage" />

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_camera"
                        android:layout_gravity="bottom|end"
                        android:contentDescription="Change Profile Picture" />
                </FrameLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/btnDeleteProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:backgroundTint="#E74C3C"
                    android:text="Delete Profile"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="12dp">
                <EditText
                    android:id="@+id/etEditFirstName"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/gray_field"
                    android:backgroundTint="#FFFFFF"
                    android:elevation="2dp"
                    android:hint="First Name"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:inputType="textPersonName"
                    tools:ignore="HardcodedText" />
                <EditText
                    android:id="@+id/etEditLastName"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/gray_field"
                    android:backgroundTint="#FFFFFF"
                    android:elevation="2dp"
                    android:hint="Last Name"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:inputType="textPersonName"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <EditText
                android:id="@+id/etEditAddress"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/gray_field"
                android:backgroundTint="#FFFFFF"
                android:elevation="2dp"
                android:hint="Address"
                android:paddingHorizontal="16dp"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:inputType="textPostalAddress"
                tools:ignore="HardcodedText" />

            <EditText
                android:id="@+id/etEditEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/gray_field"
                android:backgroundTint="#FFFFFF"
                android:elevation="2dp"
                android:hint="E-mail"
                android:paddingHorizontal="16dp"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:inputType="textEmailAddress"
                tools:ignore="HardcodedText" />

            <EditText
                android:id="@+id/etEditPhone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/gray_field"
                android:backgroundTint="#FFFFFF"
                android:elevation="2dp"
                android:hint="Phone Number"
                android:paddingHorizontal="16dp"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:inputType="phone"
                tools:ignore="HardcodedText" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="16dp">
                <EditText
                    android:id="@+id/etEditGender"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/gray_field"
                    android:backgroundTint="#FFFFFF"
                    android:elevation="2dp"
                    android:hint="Gender"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:inputType="text"
                    tools:ignore="HardcodedText" />
                <EditText
                    android:id="@+id/etEditDOB"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/gray_field"
                    android:backgroundTint="#FFFFFF"
                    android:elevation="2dp"
                    android:hint="Date of Birth"
                    android:focusable="false"
                    android:clickable="true"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    tools:ignore="HardcodedText,KeyboardInaccessibleWidget" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="16dp">
                <EditText
                    android:id="@+id/etEditGrade"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/gray_field"
                    android:backgroundTint="#FFFFFF"
                    android:elevation="2dp"
                    android:hint="Grade"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:inputType="text"
                    tools:ignore="HardcodedText" />
                <EditText
                    android:id="@+id/etEditMedium"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/gray_field"
                    android:backgroundTint="#FFFFFF"
                    android:elevation="2dp"
                    android:hint="Medium"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:inputType="text"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSaveProfile"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#F39C12"
        android:text="Save Changes"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="27dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:ignore="HardcodedText" />

</androidx.constraintlayout.widget.ConstraintLayout>