<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivCreateBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:contentDescription="@string/btn_back"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvCreateTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/create_amp_add_questions"
        android:textColor="@color/blue_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivCreateBack" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/btnSaveQuiz"
        app:layout_constraintTop_toBottomOf="@id/tvCreateTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quiz_title"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etQuizTitle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/gray_field"
                android:hint="@string/e_g_physics_term_test"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_topic"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etQuizCategory"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/gray_field"
                android:hint="@string/e_g_mechanics"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/description"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etQuizDescription"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:background="@drawable/gray_field"
                android:hint="@string/enter_instructions"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/start_date"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etStartDate"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/gray_field"
                        android:hint="@string/yyyy_mm_dd"
                        android:focusable="false"
                        android:clickable="true"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/due_date"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etDueDate"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/gray_field"
                        android:hint="YYYY-MM-DD"
                        android:focusable="false"
                        android:clickable="true"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/time_minutes"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etQuizTime"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/gray_field"
                        android:hint="@string/e_g_30"
                        android:inputType="number"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_of_questions"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etNumQuestions"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/gray_field"
                        android:hint="@string/e_g_5"
                        android:inputType="number"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D1D5DB"
                android:layout_marginVertical="24dp"/>

            <LinearLayout
                android:id="@+id/questionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btnAddNewQuestionFields"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:backgroundTint="#E8F8F5"
                android:text="@string/add_question_form"
                android:textColor="#2ECC71"
                android:textSize="12sp"
                android:textStyle="bold"
                app:strokeColor="#2ECC71"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSaveQuiz"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/blue_primary"
        android:text="@string/publish_complete_quiz"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>